# Schwab Developer App (developer.schwab.com)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1
SCHWAB_ACCOUNT_HASH=   # populated after first auth; get from /accounts endpoint

# Stored tokens (written by auth/oauth.py after initial login)
SCHWAB_ACCESS_TOKEN=
SCHWAB_REFRESH_TOKEN=
SCHWAB_TOKEN_EXPIRY=   # ISO timestamp

# Anthropic (for agent LLM calls). Default model is overridable; the spec named
# claude-sonnet-4-20250514 (an older snapshot) -- default here is the current
# Sonnet. Set ANTHROPIC_MODEL to pin a specific snapshot.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Discord (optional -- OwlGuardCo Agent Bond webhook)
DISCORD_WEBHOOK_URL=

# Safety settings
MANDATE_MAX_POSITION_USD=500
MANDATE_DAILY_LOSS_LIMIT_USD=200
MANDATE_SYMBOL_ALLOWLIST=AAPL,TSLA,NVDA,SPY,QQQ,MSFT,AMD,META,GOOGL
